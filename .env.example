# =============================================================================
# LLM API Configuration for Formula Conversion
# =============================================================================

# API Provider: openai, anthropic, google, ollama, custom
LLM_PROVIDER=openai

# API Key (obtain from your provider)
# For OpenAI: https://platform.openai.com/api-keys
# For Anthropic: https://console.anthropic.com/
# For Google: https://aistudio.google.com/app/apikey
LLM_API_KEY=

# API URL (optional, for custom endpoints or proxies)
# Default URLs:
#   - OpenAI: https://api.openai.com/v1/chat/completions
#   - Anthropic: https://api.anthropic.com/v1/messages
#   - Google: https://generativelanguage.googleapis.com/v1/models/gemini-pro:generateContent
#   - Ollama: http://localhost:11434/api/generate
LLM_API_URL=

# Model to use
# Recommendations:
#   - openai: gpt-4o-mini (fast, cheap, good for formulas)
#   - anthropic: claude-3-haiku-20240307
#   - google: gemini-1.5-flash
#   - ollama: llama3.2 (or any math-capable model)
LLM_MODEL=gpt-4o-mini

# Request settings
# Timeout de 60s para processamento de fórmulas com contexto
LLM_TIMEOUT=60
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.1

# Batch processing com chunking
# Batch size 5 para evitar timeouts
FORMULA_BATCH_SIZE=5
FORMULA_MAX_RETRIES=3

# Retry delay (segundos entre tentativas)
FORMULA_RETRY_DELAY=2

# Chunking settings - controlar chamadas API por arquivo
FORMULA_MAX_CALLS_PER_FILE=10
FORMULA_FORMULAS_PER_CALL=10

# Fallback behavior
FALLBACK_TO_IMAGES=true

# Enable LLM formula conversion (set to 1 to enable)
PDF2MD_USE_LLM=0

# Parallel processing
MAX_PARALLEL_PDFS=4
