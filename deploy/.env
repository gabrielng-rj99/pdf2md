# ============================================================================
# PDF-to-Markdown-with-Images - Docker Deployment Configuration
# ============================================================================
# IMPORTANTE: Este arquivo contém TODOS os parâmetros de configuração
# Não use valores hardcoded em scripts ou docker-compose.yml
# ============================================================================

# ==============================================================================
# SEÇÃO 1: DOMÍNIO E CERTIFICADOS
# ==============================================================================

# Domínio principal para acesso (configure também em /etc/hosts ou DNS)
DOMAIN=pdf2md.home.arpa

# Domínios alternativos separados por vírgula (para certificado SAN)
DOMAIN_ALIASES=

# Diretório onde armazenar certificados SSL/TLS
CERT_DIR=./certs

# Nome do arquivo de certificado (CRT)
CERT_CRT=pdf2md.home.arpa.crt

# Nome do arquivo de chave privada (KEY)
CERT_KEY=pdf2md.home.arpa.key

# Usar Let's Encrypt para certificados (false = auto-assinado)
LETSENCRYPT=false

# Email para notificações do Let's Encrypt
LETSENCRYPT_EMAIL=admin@home.arpa

# ==============================================================================
# SEÇÃO 2: REDE INTERNA (App + Nginx no mesmo bridge)
# ==============================================================================

# Nome da rede Docker interna (app comunicado apenas via nginx)
DOCKER_NETWORK_NAME=pdf2md_net

# Subnet da rede interna em notação CIDR
NETWORK_SUBNET=172.18.0.0/24

# Gateway da rede interna
NETWORK_GATEWAY=172.18.0.1

# ==============================================================================
# SEÇÃO 3: REDE EXTERNA (Opcional - para multi-host ou compartilhada)
# ==============================================================================

# Usar rede externa existente (true/false)
# true = espera rede já criada; false = cria rede interna automática
USE_EXTERNAL_NETWORK=false

# Nome da rede externa (se USE_EXTERNAL_NETWORK=true)
# Deixar vazio se USE_EXTERNAL_NETWORK=false
EXTERNAL_NETWORK_NAME=

# Subnet da rede externa (se USE_EXTERNAL_NETWORK=true)
EXTERNAL_NETWORK_SUBNET=172.19.0.0/24

# Gateway da rede externa (se USE_EXTERNAL_NETWORK=true)
EXTERNAL_NETWORK_GATEWAY=172.19.0.1

# ==============================================================================
# SEÇÃO 4: IPS DOS CONTAINERS - REDE INTERNA
# ==============================================================================

# IP da aplicação na rede interna (ISOLADA, sem acesso direto do host)
APP_INTERNAL_IP=172.18.0.200

# Porta interna da aplicação (acessível apenas via nginx)
APP_INTERNAL_PORT=8000

# IP do nginx na rede interna (comunica com app)
NGINX_INTERNAL_IP=172.18.0.201

# ==============================================================================
# SEÇÃO 5: IPS DOS CONTAINERS - REDE EXTERNA (Opcional)
# ==============================================================================

# IP do nginx na rede externa (se USE_EXTERNAL_NETWORK=true)
# Deixar vazio se USE_EXTERNAL_NETWORK=false
NGINX_EXTERNAL_IP=172.19.0.100

# ==============================================================================
# SEÇÃO 6: EXPOSIÇÃO DE PORTAS NO HOST (Host Binding)
# ==============================================================================

# Expor HTTP (porta 80) no host
# CUIDADO: true = qualquer um na rede pode acessar
EXPOSE_HTTP=false

# Expor HTTPS (porta 443) no host
# CUIDADO: true = qualquer um na rede pode acessar
EXPOSE_HTTPS=false

# IP do host para bind (vazio = 0.0.0.0 = todas as interfaces)
# Exemplo: 192.168.1.100 (restriciona a um IP específico)
HOST_BIND_IP=

# Porta HTTP no host
EXPOSE_HTTP_PORT=80

# Porta HTTPS no host
EXPOSE_HTTPS_PORT=443

# ==============================================================================
# SEÇÃO 7: IMAGENS E CONTAINERS
# ==============================================================================

# Nome da imagem da aplicação
APP_IMAGE=extract-pdf:latest

# Nome do container da aplicação
APP_CONTAINER_NAME=extract-pdf

# Nome da imagem do nginx
NGINX_IMAGE=nginx:stable

# Nome do container do nginx
NGINX_CONTAINER_NAME=extract-pdf-nginx

# ==============================================================================
# SEÇÃO 8: VOLUMES - CAMINHOS DO HOST
# ==============================================================================

# Diretório de output (PDFs processados e imagens)
# Caminho relativo a deploy/ ou absoluto
HOST_OUTPUT_DIR=../output

# Arquivo config.ini (configurações da aplicação)
# Caminho relativo a deploy/ ou absoluto
HOST_CONFIG_INI=../config.ini

# Diretório com arquivos de teste
# Caminho relativo a deploy/ ou absoluto
HOST_TEST_FILES_DIR=../test_files

# ==============================================================================
# SEÇÃO 9: APLICAÇÃO - GUNICORN
# ==============================================================================

# Número de workers Gunicorn (processamento paralelo)
# Recomendação: (2 * CPU_cores) + 1
# Exemplo: 4 cores = 9 workers (mas padrão 4 é seguro)
GUNICORN_WORKERS=4

# Ambiente (production/development)
ENV=production

# ==============================================================================
# SEÇÃO 10: LIMPEZA NA PARADA (init.sh down)
# ==============================================================================

# Remover rede Docker ao executar "init.sh down"
# true = remove; false = mantém rede
REMOVE_NETWORK_ON_DOWN=true

# Remover certificados gerados ao executar "init.sh down"
# true = remove (apenas desenvolvimento); false = mantém (produção)
REMOVE_CERTS_ON_DOWN=false

# ==============================================================================
# NOTAS IMPORTANTES
# ==============================================================================

# 1. CONFIGURAÇÃO DE HOSTS/DNS
#    O domínio (DOMAIN) precisa ser resolvível:
#    Linux/macOS: adicione a /etc/hosts
#      127.0.0.1 pdf2md.home.arpa
#    Windows: C:\Windows\System32\drivers\etc\hosts
#      127.0.0.1 pdf2md.home.arpa
#
# 2. ARQUITETURA DE REDE PADRÃO (USE_EXTERNAL_NETWORK=false)
#    ┌─ Host ─────────────────────────────────┐
#    │ :80/:443 → Nginx (172.18.0.201)        │
#    │             └─ App (172.18.0.200:8000) │ ISOLADO
#    └─────────────────────────────────────────┘
#    App NÃO é acessível diretamente do host
#
# 3. ARQUITETURA COM REDE EXTERNA (USE_EXTERNAL_NETWORK=true)
#    Útil para multi-host ou compartilhar rede com outros serviços
#    Requer rede já criada:
#      docker network create pdf2md_external \
#        --subnet 172.19.0.0/24 --gateway 172.19.0.1
#
# 4. CERTIFICADOS
#    - Auto-assinado: gerado automaticamente se não existir
#    - Let's Encrypt: requer domínio público e ACME configurado
#    - Duração auto-assinado: 10 anos
#    - Browser mostrará aviso (esperado para local/VPN)
#
# 5. PRIMEIRO RUN
#    cd deploy
#    bash init.sh up
#    - Cria rede
#    - Gera certificado
#    - Build imagem
#    - Inicia containers
#
# 6. PARAR
#    bash init.sh down
#    - Para containers
#    - Remove rede (se REMOVE_NETWORK_ON_DOWN=true)
#    - Remove certs (se REMOVE_CERTS_ON_DOWN=true)

# ==============================================================================
