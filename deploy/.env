INTERNAL_NETWORK_NAME=pdf2md_internal
INTERNAL_NETWORK_EXTERNAL=false
# ❌ Se INTERNAL_NETWORK_EXTERNAL=true, remova/comente até INTERNAL_NETWORK_INTERNAL:
INTERNAL_NETWORK_DRIVER=bridge
INTERNAL_NETWORK_SUBNET=172.18.1.0/24
INTERNAL_NETWORK_GATEWAY=172.18.1.1
INTERNAL_NETWORK_MTU=1500
INTERNAL_NETWORK_IPAM_DRIVER=default
INTERNAL_NETWORK_INTERNAL=false

# Segurança: bloqueie o acesso do host à rede interna!
# Exemplo iptables: sudo iptables -I DOCKER-USER -d 172.18.1.0/24 -j DROP
# Exemplo nftables: sudo nft add rule inet filter output ip daddr 172.18.1.0/24 drop

EXTERNAL_NETWORK_NAME=pdf2md_external
EXTERNAL_NETWORK_EXTERNAL=false
# ❌ Se EXTERNAL_NETWORK_EXTERNAL=true, remova/comente até EXTERNAL_NETWORK_INTERNAL:
EXTERNAL_NETWORK_DRIVER=bridge
EXTERNAL_NETWORK_SUBNET=172.18.10.0/24
EXTERNAL_NETWORK_GATEWAY=172.18.10.1
EXTERNAL_NETWORK_MTU=1500
EXTERNAL_NETWORK_IPAM_DRIVER=default
EXTERNAL_NETWORK_INTERNAL=false

APP_IMAGE=extract-pdf:latest
APP_CONTAINER_NAME=pdf2md-app
APP_PORT=8000
APP_IP=172.18.1.10
ENV=production
GUNICORN_WORKERS=4

NGINX_IMAGE=nginx:stable
NGINX_CONTAINER_NAME=pdf2md-nginx
HTTP_PORT=80
HTTPS_PORT=443
NGINX_INTERNAL_IP=172.18.1.11
NGINX_EXTERNAL_IP=172.18.10.10

HOST_OUTPUT_DIR=../output
HOST_CONFIG_INI=../config.ini
CERT_DIR=./certs
